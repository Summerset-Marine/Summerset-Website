# Summerset Marine Construction — website environment variables
#
# NOTE: On Replit, real values are managed as Secrets (padlock icon), not .env files.
# This file documents every variable the website expects, its purpose, and where
# the value comes from (Exhibit A §A.5 — environment variable reference).
#
# All VITE_* variables are BUILD-TIME: Vite bakes them into the JS bundle,
# so changing one requires a rebuild/republish, not just a restart.

# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# Purpose: browser-side content fetches (projects, testimonials, blog, market
#          pages, FAQ, lift media, team).
# Source:  manage.sanity.io → project settings. The project ID for this site
#          is mx8e8b7p; dataset is "production".
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01

# Purpose: reserved for future server-side Sanity access (not yet referenced
#          in application code).
# Source:  manage.sanity.io → API → Tokens.
SANITY_API_TOKEN=

# ─── HubSpot tracking ────────────────────────────────────────────────────────
# Purpose: when set, Layout.tsx injects the HubSpot tracking script
#          (js.hs-scripts.com/{portalId}.js) on every page.
# Source:  HubSpot → Settings → Account Setup → Account Defaults (Hub ID).
VITE_HUBSPOT_PORTAL_ID=

# ─── Site ────────────────────────────────────────────────────────────────────
# Purpose: canonical base URL used in <link rel="canonical">, OG tags, and
#          JSON-LD. SITE_URL (no VITE_ prefix) is the same value read by the
#          build-time sitemap/blog-HTML generator (scripts/generate-sitemaps.ts).
# Source:  the production domain.
VITE_SITE_URL=https://summersetmarine.com
SITE_URL=https://summersetmarine.com
