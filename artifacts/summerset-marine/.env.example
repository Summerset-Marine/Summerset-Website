# Summerset Marine Construction — environment variables
# NOTE: On Replit, real values are managed as Secrets (not .env files).
# This file documents the variables the app expects.

# Sanity CMS
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=

# NetSuite REST API
NETSUITE_ACCOUNT_ID=
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=
NETSUITE_WEBHOOK_SECRET=

# Gmail OAuth2 (Google Service Account)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_ADDRESS=
FORM_RECIPIENT_EMAIL=

# Site
VITE_SITE_URL=https://summersetmarine.com
