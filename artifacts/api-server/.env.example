# Summerset Marine Construction — API server environment variables
#
# NOTE: On Replit, real values are managed as Secrets (padlock icon), not .env files.
# This file documents every variable the API server expects, its purpose, and
# where the value comes from (Exhibit A §A.5 — environment variable reference).
#
# All integrations degrade gracefully: endpoints return 503 / typed errors
# until their variables are configured.

# ─── HubSpot Forms API ───────────────────────────────────────────────────────
# Purpose: POST /api/submit-form relays the 3 site forms (consultation,
#          contact, service-request) to HubSpot Forms API v3; consultation
#          submissions also create a CRM Deal.
# Source:  HubSpot → Settings → Integrations → Private Apps (access token,
#          scopes: forms + crm.objects.deals.write); portal/Hub ID from
#          Account Defaults; form GUIDs from Marketing → Forms.
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_ID_CONSULTATION=
HUBSPOT_FORM_ID_CONTACT=
HUBSPOT_FORM_ID_SERVICE_REQUEST=

# ─── NetSuite REST API (OAuth 1.0a, HMAC-SHA256) ─────────────────────────────
# Purpose: GET /api/inventory serves the live lift inventory (webhook-fed
#          cache in data/inventory-cache.json, falling back to a live SuiteQL
#          query); POST /api/netsuite-webhook receives incremental upsert/remove
#          events; a nightly job does a full SuiteQL pull as a safety net.
# Source:  NetSuite → Setup → Integration → Manage Integrations (consumer
#          key/secret) and Access Tokens (token id/secret); account ID from
#          Setup → Company Information.
NETSUITE_ACCOUNT_ID=
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=

# Purpose: shared secret used to verify the HMAC-SHA256 signature (hex) of the
#          raw request body sent in the x-netsuite-signature header on
#          POST /api/netsuite-webhook.
# Source:  generated by Client; must match the value configured in the
#          NetSuite-side script that pushes webhook events.
NETSUITE_WEBHOOK_SECRET=
#
# ─── NetSuite item visibility (two-field rule) ───────────────────────────────
# An item is shown on the website only when BOTH conditions are true:
#   1. custitem_smc_list_on_website = T  (a "list on website" checkbox field)
#   2. custitem_smc_status = 'Available' (a status field: Available/Pending/Sold)
# Items that are Pending, Sold, or have the flag unchecked are treated as
# removes — they never appear in the cache or on the site.
#
# This two-field approach is the current default. If a single field is
# preferred (e.g. only the status field, or only the flag), simplify the
# `isSiteVisible()` helper in src/lib/netsuite.ts and the WHERE clause in
# the SuiteQL query — no other code changes are needed.
#
# The placeholder custom field IDs (custitem_smc_*) in netsuite.ts must be
# replaced with the actual field IDs from the SMC NetSuite account before
# the direct-pull fallback and nightly reconciliation will return real data.

# ─── Server ──────────────────────────────────────────────────────────────────
# Purpose: log verbosity for the pino logger (debug | info | warn | error).
# Source:  optional; defaults apply when unset.
LOG_LEVEL=

# Purpose: standard Node environment flag ("production" in deployments).
# Source:  set automatically by the hosting platform.
NODE_ENV=
